{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C/C++: Run gpa_defender_app",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/gpa_defender_app.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "D:/software/msys2/ucrt64/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "CMake: build"
        }
    ]
}
